{
  "name": "debugger-pro-plus-3000",
  "version": "0.1.0",
  "description": "Modular debugger package for debugging websites of any framework",
  "type": "module",
  "main": "./dist/debugger-pro-plus-3000.umd.cjs",
  "module": "./dist/debugger-pro-plus-3000.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/debugger-pro-plus-3000.js",
      "require": "./dist/debugger-pro-plus-3000.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "debugger",
    "react",
    "web",
    "modular",
    "devtools"
  ],
  "author": "Slavomir Sedlak",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "insight-flow": "0.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  }
}
